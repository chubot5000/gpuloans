{
  "name": "usdai-borrow",
  "version": "1.0.0",
  "private": true,
  "browserslist": [
    "Chrome >= 92",
    "Firefox >= 90",
    "Safari >= 15.4",
    "Edge >= 92",
    "not dead"
  ],
  "scripts": {
    "dev": "next dev --turbopack -p 9002",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "type-check": "tsc --noEmit",
    "openapi-backend-dev": "openapi-typescript http://localhost:8500/swagger-json -o ./src/libs/data/clients/backend/schema.d.ts",
    "openapi-backend-prod": "openapi-typescript https://api.usd.ai/swagger-json -o ./src/libs/data/clients/backend/schema.d.ts",
    "openapi-backend-prod-dev": "openapi-typescript https://api-dev.usd.ai/swagger-json -o ./src/libs/data/clients/backend/schema.d.ts",
    "generate:pipedrive-schema": "./scripts/generate-pipedrive-schemas.sh",
    "generate:pipedrive": "node --env-file=.env.local --import tsx scripts/generate-pipedrive-constants.ts",
    "supabase:gen": "npx supabase gen types typescript --project-id zggcmphqypwbbvpexdet --schema usdai_loans > src/libs/data/supabase/database.types.ts"
  },
