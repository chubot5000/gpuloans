{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "ui/*": ["./src/libs/ui/*"],
      "logic/*": ["./src/libs/logic/*"],
      "assets/*": ["./src/libs/ui/assets/*"],
      "hooks/*": ["./src/libs/logic/hooks/*"],
      "pages/*": ["./src/libs/logic/pages/*"],
      "data/*": ["./src/libs/data/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
